# ─────────────────────────────────────────────────────────────────
#  .env.example — Template showing what variables are needed
#
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in real values in .env
#    3. Never commit .env — it is blocked by .gitignore
#
#  This file IS committed to Git — it shows teammates what
#  variables they need without exposing real values.
# ─────────────────────────────────────────────────────────────────

# ── Nessie catalogue ─────────────────────────────────────────────
NESSIE_URI=http://<your-nessie-host>:19120/api/v2
NESSIE_BRANCH=<your-branch-name>

# ── S3 / Storage ─────────────────────────────────────────────────
S3_BUCKET=<your-s3-bucket-name>
AWS_REGION=<your-aws-region>

# ── EC2 instance ─────────────────────────────────────────────────
EC2_IP=<your-ec2-ip>
EC2_USER=ubuntu
EC2_PEM_PATH=<path-to-your-pem-file>

# ── Iceberg table ────────────────────────────────────────────────
ICEBERG_CATALOG=iceberg
ICEBERG_SCHEMA=<your-schema>
ICEBERG_TABLE=<your-table-name>

# ── Auth — choose one ────────────────────────────────────────────
# Option A: IAM role attached to EC2 (recommended — no keys needed)
# S3_AUTH_METHOD=iam_role

# Option B: Access keys (only if no IAM role available)
# AWS_ACCESS_KEY=<your-access-key>
# AWS_SECRET_KEY=<your-secret-key>
