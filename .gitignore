# ─────────────────────────────────────────────────────────────────
#  .gitignore
#
#  WHY THIS FILE EXISTS:
#  Git tracks every file unless told otherwise. Some files contain
#  secrets (passwords, API keys, AWS credentials) that must never
#  be pushed to GitHub. .gitignore tells Git to permanently ignore
#  those files — even if you accidentally run "git add ."
# ─────────────────────────────────────────────────────────────────

# ── SECRETS — most critical, never commit ────────────────────────
.env                        # real credentials live here
*.pem                       # SSH private key files
*.key                       # private keys
secrets/

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# ── Spark local state ─────────────────────────────────────────────
spark-ivy-cache/
spark-warehouse/
derby.log
metastore_db/

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/
compaction.log

# ── Data files — never commit raw data ───────────────────────────
*.parquet
*.avro
data/
warehouse/

# ── OS generated ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Temp ─────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
